# Clerk (requerido para login y dashboard)
# Obtén tu key en: https://dashboard.clerk.com/last-active?path=api-keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Clerk secret key para operaciones de servidor (creación de usuario, sesiones)
CLERK_SECRET_KEY=sk_test_...
# Alternativa de fallback si tu proyecto usa la variable de entorno VITE_
VITE_CLERK_SECRET_KEY=sk_test_...
# Publishable key también en el servidor para verificar la firma de los tokens JWT
# (si no la seteas, el backend no podrá validar sesiones de Clerk)
CLERK_PUBLISHABLE_KEY=pk_test_...
# URL de JWKS de Clerk (opcional; se deriva de CLERK_PUBLISHABLE_KEY si se omite)
CLERK_JWKS_URL=
# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Base de datos (requerido para guardar datos de usuario)
DATABASE_URL=mysql://user:password@localhost:3306/ferfiit

# JWT para sesiones del servidor
JWT_SECRET=change-me-to-a-long-random-string

# API del LLM (proveedor de chat/completions, OpenAI-compatible)
# Proveedor activo: groq | opencodego | forge  (vacío = auto-detección por API key)
LLM_PROVIDER=
GROQ_SECRET_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
OPENCODEGO_SECRET_KEY=
OPENCODEGO_BASE_URL=https://api.opencodego.com/v1
OPENCODEGO_MODEL=gpt-4o-mini
# LLM_MODEL=   # opcional: sobreescribe el modelo default del provider
# Forge (fallback / features no-chat: storage, mapas, imágenes, voz)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# APIs externas (opcional)
LEONARDO_API_KEY=
MUSCLE_WIKI_API_KEY=
